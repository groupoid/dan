module adjunction where
import "library/mike/equivalence.mike"

-- An adjunction between F and G is defined by a pair of mutually inverse natural maps.
-- hom(B, F(a), b) ⊸ hom(A, a, G(b))

def AdjTo (a b) := hom(B, F(a), b) -> hom(A, a, G(b))
def AdjFrom (a b) := hom(A, a, G(b)) -> hom(B, F(a), b)
