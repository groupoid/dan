module symmetric where
import "library/mike/category.mike"

-- Symmetric Monoidal Category structure: tensor symmetry.
-- symmetry : (M1 ⊗ M2) ⊸ (M2 ⊗ M1)
-- Defined by tensor elimination followed by tensor introduction.

def SymmetryMap (M1 M2) := (M1 * M2) -> (M2 * M1)

def symmetry (M1 M2) : (M1 * M2) -> (M2 * M1) :=
  lambda(t : M1 * M2).
    let x * y := t in
    (y * x)
