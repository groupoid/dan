-- Test Permutation Group (S3 generated by transpositions)
def s3_group : PermGroup
 := П (g1 g2 : Simplex),
      g1 = Cycle (1, 2), g2 = Cycle (1, 2, 3)
    ⊢ 2 (g1, g2 | g1 = Cycle (1, 2), g2 = Cycle (1, 2, 3))

-- Test Matrix Group (SL_2(Z/2Z) generated by transpositions)
def sl2_z2 : MatGroup
 := П (m : Simplex),
      m = [[1, 1], [0, 1]]
    ⊢ 1 (m | m = [[1, 1], [0, 1]])

-- Test Finitely Presented Group (Dihedral group D3)
def fp_dihedral : FpGroup
 := П (g : FpGroup),
      g = FpGroup( a b | a^3, b^2, b ∘ a = a^2 ∘ b )
    ⊢ 1 (g | g = FpGroup( a b | a^3, b^2, b ∘ a = a^2 ∘ b ))

-- Test Actions, Orbits, and Stabilizers
def action_verify : Category
 := П (G : Group), (X : Set),
      (phi : Simplex), phi = G · X,
      Orbit(G, X) = [a, b, c],
      Stabilizer(G, X) = H
    ⊢ 3 (a, b, c | phi = phi)
