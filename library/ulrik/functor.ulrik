module functor_mod where
import "library/ulrik/category.ulrik"

-- In dirtt, a functor F : A -> B is represented by a category generator function.
functor F (x : A) : B

-- Functoriality: F maps hom(A, x, y) to hom(B, F(x), F(y))
-- Checked via path induction J on the morphism f in A, with base case id(F(z)).
check x:A, y:A | f:hom(A, x, y) ⊢ J(x_var.y_var.hom(B, F(x_var), F(y_var)), z_var, id(F(z_var)), x, y, f) : hom(B, F(x), F(y))
